{
  "name": "ai-water-meter",
  "version": "0.1.0",
  "private": true,
  "description": "A Chrome/Edge extension that estimates operational water and energy used by AI chat sessions.",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-icons.mjs && vite build && node scripts/build-content-script.mjs && node scripts/validate-extension.mjs && node scripts/package-extension.mjs",
    "lint": "eslint .",
    "format": "prettier --check .",
    "smoke": "node scripts/smoke-extension.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest --ci",
    "validate": "node scripts/validate-extension.mjs",
    "ci": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "chrome-extension",
    "ai",
    "water",
    "sustainability"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chrome": "^0.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-junit": "^17.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1"
  },
  "jest-junit": {
    "outputDirectory": "coverage",
    "outputName": "junit.xml"
  }
}
